# LINE Webhook 環境變數設定

# ==================== Domain & SSL 設定 ====================
# 你的域名 (例如: linebot.yourdomain.com)
DOMAIN=your-domain.com

# Let's Encrypt 註冊 Email
ACME_EMAIL=your-email@example.com

# ==================== LINE Bot 設定 ====================
# 從 LINE Developers Console 取得
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret

# Owner 的 LINE User ID（用於識別 Owner 的訊息）
# 多個 Owner 請用逗號分隔，例如: Uxxx,Uyyy,Uzzz
OWNER_USER_IDS=your_line_user_id

# ==================== 資料庫設定 ====================
DB_ROOT_PASSWORD=root123
DB_PASSWORD=linebot123

# ==================== LLM 設定 ====================
# 支援任意 OpenAI-compatible API
OPENAI_API_KEY=your_gemini_api_key
# API Base URL
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# 使用的模型名稱
LLM_MODEL=gemini-2.5-flash

# ==================== Embedding 設定 ====================
# 是否使用 Ollama Embeddings (BGE-m3)
USE_OLLAMA_EMBEDDINGS=true
# Ollama API URL（GPU Server）
OLLAMA_API_URL=http://your-gpu-server:11434
# Ollama Embedding 模型名稱
OLLAMA_EMBEDDING_MODEL=bge-m3

# 是否使用 Gemini Embeddings（如果 USE_OLLAMA_EMBEDDINGS=true 則忽略此設定）
USE_GEMINI_EMBEDDINGS=false
# Embedding 模型名稱
EMBEDDING_MODEL=gemini-embedding-001

# ==================== 回覆觸發設定 ====================
# 觸發自動回覆的關鍵字（逗號分隔）
AUTO_REPLY_KEYWORDS=問,查詢,help,怎麼,如何,多少錢

# Owner 多久沒回覆才觸發自動回覆（分鐘，設 0 表示立即回覆）
OWNER_RESPONSE_TIMEOUT=5
