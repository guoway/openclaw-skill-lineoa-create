# LINE Webhook Environment Configuration
# Copy this file to .env and fill in your credentials

# ==================== LINE Bot Settings ====================
# Get from https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# Owner's LINE User ID (identify after first interaction)
OWNER_USER_ID=your_owner_user_id_here

# ==================== Database Settings ====================
DB_ROOT_PASSWORD=root123
DB_PASSWORD=linebot123

# ==================== ngrok Settings ====================
# Get from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# ==================== LLM Settings ====================
# Supports any OpenAI-compatible API
OPENAI_API_KEY=your_api_key_here

# Provider-specific base URLs:
# - Moonshot: https://api.moonshot.cn/v1
# - Zaiku: https://api.zaiku.ai/v1
# - Gemini: https://generativelanguage.googleapis.com/v1beta/openai/
# - OpenRouter: https://openrouter.ai/api/v1
# - OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.moonshot.cn/v1

# Model name
LLM_MODEL=moonshot-v1-8k

# ==================== Trigger Settings ====================
# Comma-separated keywords that trigger auto-reply
AUTO_REPLY_KEYWORDS=問,查詢,help,怎麼,如何,多少錢

# Minutes to wait for owner response before auto-reply (0 = immediate)
OWNER_RESPONSE_TIMEOUT=5
